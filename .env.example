# Servidor
PORT=3000

# Base de datos MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=tours360

# Autenticación
JWT_SECRET=cambiar-por-un-valor-largo-y-secreto

# Almacenamiento de fotos: "local" o "r2"
STORAGE_DRIVER=local

# Credenciales R2 (solo si STORAGE_DRIVER=r2)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_URL=

# Email transaccional (Resend — resend.com)
RESEND_API_KEY=
EMAIL_FROM=onboarding@resend.dev

# Mercado Pago (suscripciones — mercadopago.com.ar/developers/panel/app)
MP_ACCESS_TOKEN=
MP_PUBLIC_KEY=
SUSCRIPCION_PRECIO_ARS=15000
